@using Ovk.Net.Core.Models
@model List<Club>
@{
    var targetProfile = ViewBag.TargetProfile as Profile;
    ViewData["Title"] = $"Группы {targetProfile?.FirstName}";
}

<div class="page-title">
    Группы @targetProfile?.FirstName
</div>

<div class="content_list">
    @if(Model.Count > 0)
    {
        foreach(var club in Model)
        {
            <div class="cl_element" style="padding: 10px; border-bottom: 1px solid #ccc;">
                <div class="cl_avatar" style="display: inline-block; vertical-align: top;">
                    <a href="/club@(club.Id)">
                        <img class="ava" src="/assets/packages/static/openvk/img/camera_200.png" style="width: 50px; height: 50px;" />
                    </a>
                </div>
                <div style="display: inline-block; margin-left: 10px;">
                    <a href="/club@(club.Id)" class="cl_name">
                        <b>@club.Name</b>
                    </a>
                    <div style="color: gray; font-size: 11px;">@club.About</div>
                </div>
            </div>
        }
    }
    else
    {
        <div style="padding: 15px; text-align: center; color: gray;">Пользователь не состоит в группах.</div>
    }
</div>
