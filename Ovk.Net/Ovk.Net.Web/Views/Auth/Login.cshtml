@{
    ViewData["Title"] = "Вход";
}

<form method="POST" action="/Auth/Login" enctype="multipart/form-data">
    <h4 class="reg_h4">Вход</h4>
    <table class="flexible_table auth_table" cellspacing="7" cellpadding="0" width="46%" border="0" align="center">
        <tbody>
            <tr style="text-align: right;">
                <td>
                    <span class="nobold">E-mail: </span>
                </td>
                <td style="width:191px;">
                    <input type="text" name="login" required />
                </td>
            </tr>
            <tr style="text-align: right;">
                <td>
                    <span class="nobold">Пароль: </span>
                </td>
                <td>
                    <input type="password" name="password" required />
                </td>
            </tr>
        </tbody>
    </table>
    <center>
        <input type="submit" value="Вход" class="button" />
        <a href="/Auth/Register" class="button" style="display: inline-block;">Регистрация</a><br><br>
        <a href="/Auth/Restore">Забыли пароль?</a>
    </center>
</form>
