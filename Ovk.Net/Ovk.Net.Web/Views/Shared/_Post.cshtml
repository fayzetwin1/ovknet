@model Ovk.Net.Web.Models.PostViewModel

<table border="0" style="font-size: 11px;" data-id="@Model.Id" class="post post-divider">
    <tbody>
        <tr>
            <td class="post-author-ava" width="54" valign="top">
                <a class="post-author-url" href="/id@(Model.OwnerId)">
                    <img src="@Model.OwnerMinisculeAvatarUrl" width="50" class="post-avatar" />
                    @if (Model.IsOnline)
                    {
                        <span class="post-online">Онлайн</span>
                    }
                </a>
            </td>
            <td width="100%" valign="top">
                <div class="post-author">
                    <a href="/id@(Model.OwnerId)"><b class="post-author-name">@Model.OwnerName</b></a>
                    @if (Model.IsVerified)
                    {
                        <img class="name-checkmark" src="/assets/packages/static/openvk/img/checkmark.png">
                    }
                    
                    @if (Model.IsFemale)
                    {
                        <span>написала</span>
                    }
                    else
                    {
                        <span>написал</span>
                    }
                    
                    @if (Model.TargetWallId != Model.OwnerId && Model.TargetWallId > 0)
                    {
                        <a href="/id@(Model.TargetWallId)" class="mention">
                            <b>сообщение на стене</b>
                        </a>
                    }
                    
                    @if (Model.CanBeDeleted)
                    {
                        <a class="delete" href="javascript:void(0)" onclick="deletePost(@Model.Id)"></a>
                    }
                    
                    @if (Model.CanBePinned)
                    {
                        if (Model.IsPinned)
                        {
                            <a class="pin" href="javascript:void(0)" onclick="unpinPost(@Model.Id)"></a>
                        }
                        else
                        {
                            <a class="pin" href="javascript:void(0)" onclick="pinPost(@Model.Id)"></a>
                        }
                    }
                </div>
                <div class="post-content" id="@Model.Id">
                    <div class="text" id="text@(Model.Id)">
                        <span data-text="@Model.Content" class="really_text post_text">@Model.Content</span>
                    </div>
                </div>
                <div class='post-edit'></div>
                <div class="post-menu">
                    <a href="/wall@(Model.Id)" class="date">@Model.PrettyDate</a>
                  
                    &nbsp;

                    <a href="javascript:expand_comment_textarea(@Model.Id)">Комментировать</a>
                    
                    <div class="like_wrap">
                        <a id="reposts@(Model.Id)" class="post-share-button" href="javascript:repost('@Model.Id', 'post')">
                            <div class="repost-icon" style="opacity: 0.4;"></div>
                            <span class="likeCnt" id="repostsCount@(Model.Id)">@(Model.RepostsCount > 0 ? Model.RepostsCount.ToString() : "")</span>
                        </a>

                        <a href="javascript:likePost(@Model.Id)" class="post-like-button" data-liked="@(Model.IsLikedByCurrentUser ? 1 : 0)" data-likes="@Model.LikesCount" data-id="@Model.Id" data-type='post'>
                            <div class="heart" id="@(Model.IsLikedByCurrentUser ? "liked" : "")"></div>
                            <span class="likeCnt">@(Model.LikesCount > 0 ? Model.LikesCount.ToString() : "")</span>
                        </a>
                    </div>
                </div>
            </td>
        </tr>
    </tbody>
</table>
